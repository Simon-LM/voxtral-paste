# VoxRefiner — Configuration template
# Copy this file to .env and fill in your values
# NEVER commit your .env file

# ─── API Keys ─────────────────────────────────────────────────────────────────
#
# Priority rule: when both a direct key AND an Eden AI key are set, VoxRefiner
# always uses the direct API first (lower latency, lower cost). Eden AI is used
# as fallback only — either on 429 rate-limit or when no direct key is available.
#
# Exception: MISTRAL_API_KEY is always required (Voxtral STT/TTS is Mistral-only).

# ── Required ──────────────────────────────────────────────────────────────────

# Mistral API key — required for Voxtral transcription and text refinement.
# VoxRefiner cannot function without it.
# Get yours at: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your_mistral_api_key_here

# ── Optional: direct provider keys ───────────────────────────────────────────
# Adding a direct key enables that provider at higher priority than Eden AI.
# You can combine direct keys with EDENAI_API_KEY for maximum redundancy.

# Perplexity API key — enables web search and fact-checking via Perplexity (direct).
# Priority engine for search/fact-check in auto mode. Minimum ~50 EUR credit recommended.
# Without this key, Perplexity is still accessible via EDENAI_API_KEY (Eden route).
# Get yours at: perplexity.ai/settings/api
# PERPLEXITY_API_KEY=your_perplexity_api_key_here

# xAI / Grok API key — enables Grok search (web + X/Twitter) via direct API.
# Key advantage of the direct key: native X/Twitter search (not available via Eden AI).
# Without this key, Grok is still accessible via EDENAI_API_KEY (Eden route, no X search).
# Get yours at: x.ai/api
# XAI_API_KEY=your_xai_api_key_here

# ── Optional: Eden AI (redundancy + additional capabilities) ──────────────────
# Eden AI provides a single key for Mistral, Grok, Perplexity, Gemini, and OVH models.
# Used as fallback when direct providers are rate-limited, and for OCR and Gemini routes.
# Does NOT replace MISTRAL_API_KEY (Voxtral is not available via Eden).
# Get yours at: https://app.edenai.run/user/settings
# EDENAI_API_KEY=your_edenai_api_key_here

# ── Reserved for future use (not yet active) ─────────────────────────────────
# GEMINI_API_KEY — Gemini direct + Google Search grounding (endpoint not yet wired).
# GEMINI_API_KEY=your_gemini_api_key_here

# ─── Output formatting ────────────────────────────────────────────────────────
# How should your refined text be structured?
# Applies to medium and long transcriptions only (≥ 80 words).
# Short texts are always plain, regardless of this setting.
#
#   plain         — flowing text, no structure
#   prose         — clean paragraphs, no lists → general use, screen readers (default)
#   accessibility — alias for prose
#   structured    — paragraphs + bullet points → AI chat, brainstorming, developers
#   dev           — alias for structured
#   technical     — Markdown: ## headers, paragraphs, - bullet points → .md files, docs
OUTPUT_PROFILE=prose

# Output language — only English override is supported for now.
#
# Not set / empty : VoxRefiner replies in the same language you speak (default).
#                   If you speak French → output is French.
#                   Technical terms (commit, push…) are preserved as-is.
#
# en              : VoxRefiner always replies in English, even if you speak
#                   another language. Useful for developers working in English-
#                   only tools (VS Code, Claude Code).
#
# Other values (fr, es…) are NOT supported and will be ignored with a warning.
# To disable: comment out or delete the line below.
# OUTPUT_LANG=en

# ─── Context & history ────────────────────────────────────────────────────────
# VoxRefiner can learn your vocabulary and work context over time.
# When enabled, key facts are extracted from your longer transcriptions and saved
# to history.txt — then injected into future prompts for smarter refinement.
#
# Why opt-in? history.txt may contain private information (projects, tools,
# decisions). It stays on your machine and is never committed to git, but you
# should decide consciously whether to activate it.
#
# Recommended: enable it once you have tested the basic workflow.
# To enable: change false to true
ENABLE_HISTORY=false    # ← set to true to enable

# Maximum number of bullets kept in history.txt (oldest are dropped when limit is reached).
HISTORY_MAX_BULLETS=80

# Bullets injected into the prompt for medium-length transcriptions (80–240 words).
# Only the most recent N bullets are sent — keeps the prompt focused without removing
# bullets from the file. Short texts (<80 words) receive no history. Long texts (>240 words)
# always receive the full history regardless of this setting.
HISTORY_INJECT_BULLETS_MEDIUM=40

# ─── Audio processing ─────────────────────────────────────────────────────────
# Speed multiplier applied to audio before transcription.
# Faster audio reduces API processing time and cost, but may increase errors
# for fast speakers or strong accents.
#
#   1.25 — recommended starting point (conservative, fewer errors)   ← this file
#   1.5  — ideal for clear, moderate-pace speakers                   ← code default if unset
#   1.0  — no speed change (maximum accuracy, slowest processing)
#   2.0  — maximum speed (may cause errors for most speakers)
#
# Accepted range: 1.0 – 2.0
AUDIO_TEMPO=1.25

# ─── Advanced: model routing ──────────────────────────────────────────────────
# These defaults are tested and recommended — change only to experiment with
# alternative models for specific use cases.

# Word count thresholds for 3-tier routing (defaults: 80 / 240)
REFINE_MODEL_THRESHOLD_SHORT=80
REFINE_MODEL_THRESHOLD_LONG=240

# Tier 1 — short transcriptions (< THRESHOLD_SHORT words) — fast & cheap
#   temperature=0.2, top_p=0.85 (conservative, faithful corrections)
REFINE_MODEL_SHORT=mistral-small-latest
REFINE_MODEL_SHORT_FALLBACK=mistral-medium-latest

# Tier 2 — medium transcriptions (THRESHOLD_SHORT to THRESHOLD_LONG words) — balanced
#   temperature=0.3, top_p=0.9, reasoning_effort=high
#   Mistral Small 4 with reasoning replaces Magistral Small — similar quality,
#   faster and cheaper.
#   Note: reasoning_effort is only supported by mistral-small-latest. If you
#   override this to another model, reasoning_effort is automatically stripped.
REFINE_MODEL_MEDIUM=mistral-small-latest
REFINE_MODEL_MEDIUM_FALLBACK=mistral-medium-latest

# Tier 3 — long transcriptions (>= THRESHOLD_LONG words) — deep reasoning
#   temperature=0.4, top_p=0.9 (native reasoning via Magistral)
REFINE_MODEL_LONG=magistral-medium-latest
REFINE_MODEL_LONG_FALLBACK=mistral-medium-latest

# ─── Advanced: history extraction models ──────────────────────────────────────
# Only relevant if ENABLE_HISTORY=true. A small model is sufficient here.
HISTORY_EXTRACTION_MODEL=mistral-small-latest
HISTORY_EXTRACTION_FALLBACK_MODEL=mistral-medium-latest
HISTORY_TIMEOUT_MULTIPLIER=1.5

# ─── Advanced: modes ──────────────────────────────────────────────────────────

# Set to false to skip AI refinement entirely.
# The raw Voxtral transcription is copied to clipboard as-is (no Mistral chat call).
ENABLE_REFINE=true

# Show the raw Voxtral transcription alongside the refined result.
# Useful to compare what Voxtral heard vs what the AI produced — without
# running a second model. No extra API call, no added cost or delay.
# Enabled by default so you can immediately see the difference between
# raw transcription and AI-refined output.
# To disable: change true to false
SHOW_RAW_VOXTRAL=true

# Run both primary and fallback models in parallel and display all three outputs:
# [1] Raw Voxtral  [2] Primary (copied to clipboard)  [3] Fallback
# Implies SHOW_RAW_VOXTRAL. Useful for comparing model quality side by side.
# To enable: change false to true
REFINE_COMPARE_MODELS=false    # ← set to true to enable

# ─── Advanced: resilience ─────────────────────────────────────────────────────
# Timeouts are computed automatically from file size (Voxtral) and word count (Refine).
# Extra retry attempts on transient HTTP errors (429 / 500 / 502 / 503).
# Total attempts = 1 + retries. Set to 0 to disable retries.
TRANSCRIBE_REQUEST_RETRIES=2
REFINE_REQUEST_RETRIES=2
TTS_REQUEST_RETRIES=2

# ─── Language ─────────────────────────────────────────────────────────────────
# Default language for all AI-generated content (summaries, fact-checks, search,
# translation). When set, VoxRefiner always responds in this language, regardless
# of the input text's language.
#
# When unset: falls back to TRANSLATE_TARGET_LANG (set via Settings menus).
# When both unset: the AI responds in the same language as the input text
# (natural behaviour — a French article will be summarised in French).
#
# Supported codes: en, fr, de, es, pt, it, nl, hi, ar, zh, ja, ko, ru, pl, sv
# Example: OUTPUT_DEFAULT_LANG=fr
# OUTPUT_DEFAULT_LANG=

# ─── Voice Translate ─────────────────────────────────────────────────────────
# Speak in one language, get an audio translation in your own voice.
# Available from the interactive menu (VoxRefiner app launcher).

# Default target language for the 🎙→🔊 Voice Translate module.
# This is DISTINCT from TRANSLATE_TARGET_LANG: Voice Translate translates
# FROM the user's native language TO this language, whereas TRANSLATE_TARGET_LANG
# means "output AI content IN this language" (user's native language).
# Persisted at runtime via [s] Save lang default in the post-translate menu.
# Supported: en, fr, de, es, pt, it, nl, hi, ar
VOICE_TRANSLATE_TARGET_LANG=en

# Override output language for text-based translation flows (Selection to Voice
# auto-translate, Voice Translate pipeline). When set, takes precedence over
# OUTPUT_DEFAULT_LANG for those flows only.
# Leave unset to use OUTPUT_DEFAULT_LANG as translation target.
# Supported: en, fr, de, es, pt, it, nl, hi, ar
# TRANSLATE_TARGET_LANG=

# Language for auto-generated filename slugs when saving Voice Translate audio.
# auto = same language as the spoken input (default)
# en   = always English regardless of input language
SAVE_SLUG_LANG=auto

# TTS model for speech synthesis
TTS_MODEL=voxtral-mini-tts-2603

# Default TTS voice ID (used when recording is too short for voice cloning).
# Default: Paul - Neutral (en_us)
TTS_DEFAULT_VOICE_ID=c69964a6-ab8b-4f8a-9465-ec0925096ec8

# Voice used by Selection to Voice (option [4]).
# Use the UUID from GET https://api.mistral.ai/v1/audio/voices
# French (Marie): neutral=5a271406-039d-46fe-835b-fbbb00eaf08d
#                 happy=49d024dd  sad=4adeb2c6  excited=2f62b1af
#                 curious=e0580ce5  angry=a7c07cdc
# English (Paul): neutral=c69964a6-ab8b-4f8a-9465-ec0925096ec8
#                 (+ happy/sad/excited/confident/cheerful/angry/frustrated)
# English GB (Oliver): neutral=e3596645 | (Jane): neutral=82c99ee6
TTS_SELECTION_VOICE_ID=e0580ce5-e63c-4cbe-88c8-a983b80c5f1f

# Auto-translate selected text before reading aloud (Selection to Voice).
# 0 = disabled (default) — reads the text as-is in its original language.
# 1 = enabled — translates to TRANSLATE_TARGET_LANG (or OUTPUT_DEFAULT_LANG)
#     before sending to TTS. Useful when you always want audio in your language
#     regardless of the source text's language.
# Configurable at runtime via [s] Settings in the Selection to Voice post-menu.
TTS_AUTO_TRANSLATE=0

# Loudness normalization target (EBU R128, in LUFS).
# Standardizes audio volume regardless of mic distance or input level.
#  -16 — podcast / spoken word standard (default, recommended)
#  -14 — louder (mobile listening, noisy environments)
#  -23 — broadcast TV standard (quieter)
TTS_LOUDNESS=-16

# Volume boost applied AFTER normalization.
# Useful to push the output louder for speakers/headphones with low output.
#   1.0 — no boost (normalized level only)
#   2.0 — double volume (default)
#   3.0 — triple volume (for quiet setups)
TTS_VOLUME=2.0

# Audio player command for TTS output (mpv recommended)
TTS_PLAYER="mpv --no-video"

# Voice sample: seconds to skip from start (avoid hesitations at recording start)
TTS_VOICE_SKIP_SECONDS=3

# Voice sample: duration in seconds (Voxtral TTS recommends 10-20s)
TTS_VOICE_SAMPLE_DURATION=15

# AI model for voice rewrite (clean + adapt for speech + translate)
# mistral-small-latest with reasoning is recommended for translation quality.
VOICE_REWRITE_MODEL=mistral-small-latest
VOICE_REWRITE_MODEL_FALLBACK=mistral-medium-latest
VOICE_REWRITE_RETRIES=2

# ─── Advanced: Selection to Insight models ────────────────────────────────────
# Only relevant if PERPLEXITY_API_KEY and/or XAI_API_KEY are set.

# Model used for bullet-point summarisation (mistral-small with reasoning).
INSIGHT_SUMMARY_MODEL=mistral-small-latest

# Model used for fact-check synthesis (combines Perplexity + Grok reports).
# Only called when BOTH Perplexity and Grok are available simultaneously.
INSIGHT_SYNTHESIS_MODEL=mistral-small-latest

# Perplexity model for web search and fact-checking.
# sonar-pro offers citations and deeper search; sonar is faster and cheaper.
INSIGHT_PERPLEXITY_MODEL=sonar-pro

# Grok model for web + X search and fact-checking.
# Server-side tools (web_search, x_search) require the grok-4 family minimum.
# grok-4 is the most capable; grok-4-fast is faster and cheaper (default).
INSIGHT_GROK_MODEL=grok-4-fast

# Search engine selection for [p] Search in the Insight menu.
#   auto        → Perplexity if PERPLEXITY_API_KEY set, else Grok (default)
#   perplexity  → always use Perplexity
#   grok        → always use Grok
#   both        → run both in parallel, synthesise with Mistral (slower)
# INSIGHT_SEARCH_ENGINE=auto

# Fact-check synthesis reasoning effort (only used when BOTH keys are set).
#   standard  → no extended reasoning — fast (default)
#   high      → reasoning_effort: high — slower but more thorough
# INSIGHT_SYNTHESIS_REASONING=standard
