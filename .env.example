# Voxtral Paste — Configuration template
# Copy this file to .env and fill in your values
# NEVER commit your .env file

# ─── Required ─────────────────────────────────────────────────────────────────

# Your Mistral API key
# Get yours at: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your_mistral_api_key_here

# ─── Optional: audio processing ─────────────────────────────────────────────

# Speed multiplier applied to recorded audio before transcription.
# Lower values reduce transcription errors (1.0 = no speed change, 1.5 = default).
# Accepted range: 0.5 – 2.0
AUDIO_TEMPO=1.5

# ─── Optional: model routing ──────────────────────────────────────────────────

# Word count thresholds for 3-tier model routing (defaults: 90 / 240)
REFINE_MODEL_THRESHOLD_SHORT=90
REFINE_MODEL_THRESHOLD_LONG=240

# Tier 1 — short transcriptions (< THRESHOLD_SHORT words) — fast & cheap
REFINE_MODEL_SHORT=devstral-small-latest
REFINE_MODEL_SHORT_FALLBACK=mistral-small-latest

# Tier 2 — medium transcriptions (THRESHOLD_SHORT to THRESHOLD_LONG words) — balanced
REFINE_MODEL_MEDIUM=magistral-small-latest
REFINE_MODEL_MEDIUM_FALLBACK=mistral-medium-latest

# Tier 3 — long transcriptions (>= THRESHOLD_LONG words) — deep reasoning
REFINE_MODEL_LONG=magistral-medium-latest
REFINE_MODEL_LONG_FALLBACK=mistral-large-latest

# ─── Optional: history (automatic context enrichment) ───────────────────────────────────

# Set to true to enable automatic history extraction after MEDIUM/LONG transcriptions.
# When enabled, voxtral-paste extracts contextual facts (projects, tools, decisions)
# from each refined text and appends them to history.txt. This history is then injected
# into all future prompts to improve relevance and understanding of your work context.
# The history.txt file stays on your machine — it is never stored by Mistral.
ENABLE_HISTORY=false

# Maximum number of bullet points kept in history.txt (oldest are dropped first).
HISTORY_MAX_BULLETS=60

# Model used for history extraction (a small model is sufficient — the task is simple).
HISTORY_EXTRACTION_MODEL=magistral-small-latest
